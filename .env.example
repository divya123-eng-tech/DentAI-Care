SECRET_KEY=change-this-secret

# MySQL example:
# DATABASE_URL=mysql+pymysql://root:password@localhost/dent_ai_care

# If DATABASE_URL is not set, the app uses instance/dent_ai_care.db SQLite
# so you can run the project immediately for demo and viva.
DATABASE_URL=

# Optional email setup. Use these to send real OTPs and PDF reports by email.
# For Gmail, use an App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
